# LLM 提供商配置
# 可选: deepseek, openai, ollama
# ollama 用于 V4：把 LLM_PROVIDER 改成 ollama，即可调用本地微调模型
LLM_PROVIDER=deepseek

# DeepSeek 配置
# 注册地址: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# OpenAI 配置（用于 Embedding，RAG 功能需要）
# 获取地址: https://platform.openai.com
# 或者使用硅基流动（国内可用，OpenAI 兼容）: https://cloud.siliconflow.cn
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
# 如果使用硅基流动，改为: OPENAI_BASE_URL=https://api.siliconflow.cn/v1

# 模型配置
DEFAULT_MODEL=deepseek-chat
TEMPERATURE=0.7
MAX_TOKENS=2000

# 历史记录配置
# 当历史消息 token 数超过此值时，会自动截断最早的对话
MAX_HISTORY_TOKENS=4000

# 系统提示词
SYSTEM_PROMPT=你是一个 helpful 的 AI 助手。

# ============================================
# 【V3 新增】Agent 智能体配置
# ============================================

# Tavily 网页搜索 API Key（Agent 的网页搜索工具用）
# 每月 1000 次免费额度，注册地址: https://tavily.com
# 不填也能用其他工具，只是网页搜索不可用
TAVILY_API_KEY=your_tavily_api_key_here

# Agent 最大循环次数（防止工具调用无限循环，控制费用）
AGENT_MAX_ITERATIONS=5

# ============================================
# 【V4 新增】本地部署 / 多模态配置
# ============================================

# Ollama 本地模型地址（把 LLM_PROVIDER 设为 ollama 时生效）
OLLAMA_BASE_URL=http://localhost:11434/v1
# 本地模型名称（如 qwen2.5:7b，或你微调导出后自己命名的 my-brain）
OLLAMA_MODEL=qwen2.5:7b

# ============================================
# 企业智能管理工作台
# ============================================

# 本地模型调用超时（秒）。不启用 AI 时不会调用模型。
ENTERPRISE_MODEL_TIMEOUT=20

# 只有用户在单次操作中明确勾选“脱敏后调用外部模型”时才会读取以下配置。
# 可选: deepseek, openai
ENTERPRISE_EXTERNAL_PROVIDER=deepseek
# 留空时使用对应提供商的默认模型。
ENTERPRISE_EXTERNAL_MODEL=deepseek-chat

# 任意 Python 代码执行工具默认关闭。企业环境不要启用。
ENABLE_UNSAFE_PYTHON_TOOL=0

# 多模态视觉模型（图片 OCR 用，复用上面的 OPENAI_API_KEY / OPENAI_BASE_URL）
VISION_MODEL=gpt-4o
